rules_version = '2';

// Permissive rules for local emulator development.
// These rules allow all authenticated users full read/write access.
// NEVER deploy these to production — use firestore.rules instead.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
