# =============================================================================
# OR Scheduler — Environment Variables
# =============================================================================
# Copy this file to .env:  cp .env.example .env
#
# For local development with emulators, these are optional.
# They're only needed for production SMS/email notifications.
# =============================================================================

# Twilio (SMS notifications) — optional for local dev
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firebase Cloud Function (SMS relay) — optional for local dev
CLOUD_FUNCTION_URL=

# Email (SendGrid) — optional for local dev
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=noreply@orscheduler.com
EMAIL_SEND_ENDPOINT=https://api.sendgrid.com/v3/mail/send
